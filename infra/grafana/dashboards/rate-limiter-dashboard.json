{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Request rate — allowed vs denied",
      "description": "Per-second rate of rate-limit decisions, broken down by algorithm and outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ratelimiter_decisions_total[5m])) by (algorithm, decision)",
          "legendFormat": "{{algorithm}} — {{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 2,
      "title": "Deny rate %",
      "description": "What percentage of all requests are being denied. Alert if this exceeds 5%.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(ratelimiter_decisions_total{decision=\"denied\"}[5m])) / sum(rate(ratelimiter_decisions_total[5m]))",
          "legendFormat": "Deny %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Redis failure count (5m window)",
      "description": "Any non-zero value = Redis had connectivity issues. Investigate immediately.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "increase(ratelimiter_redis_failures_total[5m])",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },

    {
      "id": 4,
      "title": "Average Redis evaluation latency (ms)",
      "description": "Time the Lua script takes in Redis. Healthy = under 2ms. Alert at 10ms.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(ratelimiter_redis_duration_ms_sum[5m]) / rate(ratelimiter_redis_duration_ms_count[5m])",
          "legendFormat": "Avg latency (ms) — {{algorithm}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Total decisions (counter)",
      "description": "Cumulative count of all decisions since startup. Sanity check.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(ratelimiter_decisions_total) by (decision)",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["rate-limiter", "redis", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Rate Limiter — Operations Dashboard",
  "uid": "rate-limiter-ops-v1",
  "version": 1
}